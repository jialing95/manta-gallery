{
  "id": "aqaba_case_001",
  "title": "Aqaba landslide-tsunami simulation",
  "description": "Interactive 3D view of wave-amplitude evolution and landslide material fields.",
  "time": {
    "unit": "s",
    "values": [0, 60, 120, 180, 240],
    "default_index": 0
  },
  "layers": {
    "terrain": {
      "file": "terrain.vtp",
      "visible": true,
      "style": {
        "mode": "sea_split",
        "below_sea_level": {
          "label": "Bathymetry",
          "colormap": "cmocean.deep"
        },
        "above_sea_level": {
          "label": "Topography",
          "colormap": "cmcrameri.grayC",
          "relief": true
        }
      }
    },
    "water": {
      "file_pattern": "water/frame_{frame}.vtp",
      "visible": true,
      "display_scalar": "wave_amplitude",
      "filter_scalar": "m",
      "filter_rule": "m <= water_m",
      "default_m": 0.001,
      "m_range": [0.0, 1.0],
      "label": "Wave amplitude",
      "unit": "m",
      "colormap": "dclaw.tsunami",
      "colormap_label": "Tsunami",
      "colorbar": {
        "side": "right",
        "range": [-2.0, 2.0]
      }
    },
    "landslide": {
      "file_pattern": "landslide/frame_{frame}.vtp",
      "visible": true,
      "filter_scalar": "m",
      "filter_rule": "m >= landslide_m",
      "default_m": 0.30,
      "m_range": [0.0, 1.0],
      "default_scalar": "hm",
      "colormap": "magma",
      "colorbar": {
        "side": "left"
      },
      "available_scalars": {
        "hm": {
          "label": "hm (solid thickness)",
          "unit": "m"
        },
        "m": {
          "label": "m (solid fraction)",
          "unit": "1",
          "range": [0.30, 1.0]
        },
        "db": {
          "label": "Δb (bed change)",
          "unit": "m"
        }
      }
    }
  },
  "ui": {
    "show_layer_toggles": true,
    "show_time_slider": true,
    "show_water_m_slider": true,
    "show_landslide_m_slider": true,
    "show_landslide_scalar_selector": true,
    "show_colormap_controls": false,
    "show_dem_style_controls": false,
    "show_vertical_exaggeration": false
  },
  "camera": {
    "preset": "oblique"
  }
}